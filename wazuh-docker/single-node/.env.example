# =============================================================================
# Wazuh GraphRAG 整合監控系統 - 統一環境變數配置
# 版本: 2.0
# 描述: 整合所有服務的環境變數到單一配置檔案
# 使用方式: 複製此檔案為 .env 並根據您的環境調整配置
# =============================================================================

# =============================================================================
# 📦 構建與部署配置
# =============================================================================
BUILD_ENV=production                      # 構建環境: production, development
PYTHON_VERSION=3.11                       # Python 版本
WAZUH_VERSION=4.7.4                       # Wazuh 版本
WAZUH_TAG_REVISION=1                      # Wazuh 標籤修訂版本

# =============================================================================
# 🔐 Wazuh 安全配置
# =============================================================================
WAZUH_ADMIN_PASSWORD=SecretPassword       # Wazuh 管理員密碼
WAZUH_INDEXER_PASSWORD=SecretPassword     # Wazuh Indexer 密碼
WAZUH_API_USERNAME=wazuh-wui              # Wazuh API 使用者名稱
WAZUH_API_PASSWORD=MyS3cr37P450r.*-       # Wazuh API 密碼
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g       # OpenSearch JVM 選項

# =============================================================================
# 🧩 Neo4j 圖形資料庫配置
# =============================================================================
NEO4J_USER=neo4j                          # Neo4j 使用者名稱
NEO4J_PASSWORD=wazuh-graph-2024           # Neo4j 密碼
NEO4J_URI=bolt://neo4j:7687               # Neo4j 連接 URI
NEO4J_HEAP_SIZE=2G                        # Neo4j 堆積記憶體大小
NEO4J_PAGECACHE_SIZE=1G                   # Neo4j 頁面快取大小
NEO4J_MAX_CONNECTION_POOL_SIZE=50         # Neo4j 連接池大小
NEO4J_CONNECTION_TIMEOUT=30               # Neo4j 連接超時(秒)
NEO4J_MAX_TRANSACTION_RETRY_TIME=30       # Neo4j 交易重試時間(秒)

# =============================================================================
# 📊 Grafana 監控配置
# =============================================================================
GRAFANA_ADMIN_USER=admin                  # Grafana 管理員使用者名稱
GRAFANA_ADMIN_PASSWORD=wazuh-grafana-2024 # Grafana 管理員密碼
GRAFANA_SESSION_TIMEOUT=24h               # Grafana 會話超時時間

# =============================================================================
# 📈 Prometheus 監控配置
# =============================================================================
PROMETHEUS_RETENTION_DAYS=30              # Prometheus 資料保留天數
METRICS_COLLECTION_INTERVAL=15            # 指標收集間隔(秒)
METRICS_RETENTION_DAYS=30                 # 指標保留天數

# =============================================================================
# 🤖 AI Agent 配置
# =============================================================================
AI_AGENT_LOG_LEVEL=INFO                   # AI Agent 日誌等級: DEBUG, INFO, WARNING, ERROR
AI_AGENT_WORKERS=1                        # AI Agent 工作程序數量
ENABLE_GRAPH_PERSISTENCE=true             # 啟用圖形持久化
GRAPH_BATCH_SIZE=100                      # 圖形批次大小
GRAPH_MAX_ENTITIES_PER_ALERT=50           # 每個警報的最大實體數
METRICS_ENABLED=true                      # 啟用指標收集
METRICS_PORT=8000                         # 指標服務連接埠

# =============================================================================
# 🔌 資料庫連接池配置
# =============================================================================
# OpenSearch 連接配置
OPENSEARCH_MAX_CONNECTIONS=20             # OpenSearch 最大連接數
OPENSEARCH_MAX_KEEPALIVE_CONNECTIONS=10   # OpenSearch 最大保持連接數
OPENSEARCH_KEEPALIVE_TIMEOUT=300          # OpenSearch 保持連接超時(秒)
OPENSEARCH_CONNECTION_TIMEOUT=30          # OpenSearch 連接超時(秒)
OPENSEARCH_READ_TIMEOUT=60                # OpenSearch 讀取超時(秒)

# =============================================================================
# 🚀 向量化服務優化
# =============================================================================
EMBEDDING_BATCH_SIZE=20                   # 嵌入批次大小
EMBEDDING_MAX_CONCURRENT=3                # 最大並發嵌入數
EMBEDDING_CACHE_SIZE=1000                 # 嵌入快取大小
EMBEDDING_CACHE_TTL=3600                  # 嵌入快取 TTL(秒)
EMBEDDING_CACHE_ENABLED=true              # 啟用嵌入快取

# =============================================================================
# 🧠 LLM API 優化
# =============================================================================
LLM_MAX_RETRIES=3                         # LLM 最大重試次數
LLM_TIMEOUT=120                           # LLM 超時(秒)
LLM_MAX_TOKENS=4096                       # LLM 最大令牌數
LLM_TEMPERATURE=0.3                       # LLM 溫度參數

# =============================================================================
# ⚡ 並發處理配置
# =============================================================================
ALERT_PROCESSING_CONCURRENCY=5            # 警報處理並發數
ALERT_BATCH_SIZE=10                       # 警報批次大小
ALERT_PROCESSING_INTERVAL=60              # 警報處理間隔(秒)

# =============================================================================
# 💾 快取配置
# =============================================================================
CACHE_ENABLED=true                        # 啟用快取
CACHE_LRU_MAXSIZE=1000                    # LRU 快取最大大小
CACHE_TTL_MAXSIZE=500                     # TTL 快取最大大小
CACHE_TTL_SECONDS=3600                    # 快取 TTL(秒)

# Redis 快取（未來擴展用）
REDIS_URL=redis://localhost:6379          # Redis URL
REDIS_CACHE_TTL=1800                      # Redis 快取 TTL(秒)
REDIS_MAX_CONNECTIONS=10                  # Redis 最大連接數

# =============================================================================
# 💻 系統資源配置
# =============================================================================
PYTHONUNBUFFERED=1                        # Python 無緩衝輸出
PYTHONDONTWRITEBYTECODE=1                 # Python 不寫入 bytecode
OMP_NUM_THREADS=4                         # OpenMP 執行緒數

# =============================================================================
# 🌐 網路配置
# =============================================================================
DOCKER_NETWORK_NAME=wazuh-graphrag-net    # Docker 網路名稱

# =============================================================================
# 🏢 生產環境優化（當 BUILD_ENV=production 時啟用）
# =============================================================================
# 取消以下註解以在生產環境中使用優化配置
# AI_AGENT_LOG_LEVEL=WARNING
# AI_AGENT_WORKERS=2
# NEO4J_HEAP_SIZE=4G
# NEO4J_PAGECACHE_SIZE=2G
# OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g
# OPENSEARCH_MAX_CONNECTIONS=50
# EMBEDDING_BATCH_SIZE=50
# EMBEDDING_MAX_CONCURRENT=5
# ALERT_PROCESSING_CONCURRENCY=10