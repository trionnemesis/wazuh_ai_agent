{
  "index_patterns": ["wazuh-alerts-*"],
  "priority": 1,
  "template": {
    "settings": {
      "index.knn": true,
      "index.knn.algo_param.ef_search": 100
    },
    "mappings": {
      "properties": {
        "alert_vector": {
          "type": "knn_vector",
          "dimension": 768,
          "method": {
            "name": "hnsw",
            "space_type": "cosinesimil",
            "engine": "nmslib",
            "parameters": {
              "ef_construction": 256,
              "m": 48
            }
          }
        },
        "ai_analysis": {
          "type": "object",
          "properties": {
            "triage_report": {
              "type": "text",
              "analyzer": "standard"
            },
            "provider": {
              "type": "keyword"
            },
            "timestamp": {
              "type": "date"
            },
            "risk_level": {
              "type": "keyword"
            },
            "vector_dimension": {
              "type": "integer"
            },
            "processing_time_ms": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}